{
    "name": "flowrise-hms/diagnostics",
    "type": "laravel-module",
    "description": "Unified diagnostics workflows for laboratory, radiology, and pathology in FlowRise HMS",
    "keywords": [
        "flowrise",
        "hms",
        "diagnostics",
        "laboratory",
        "radiology",
        "pathology",
        "fhir",
        "loinc",
        "filament"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Flowrise Digital",
            "email": "flowrisedigitals@gmail.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "flowrise-hms/core": "dev-main",
        "flowrise-hms/clinical": "dev-main"
    },
    "extra": {
        "laravel": {
            "providers": [],
            "aliases": {}
        }
    },
    "autoload": {
        "psr-4": {
            "Modules\\Diagnostics\\": "app/",
            "Modules\\Diagnostics\\Database\\Factories\\": "database/factories/",
            "Modules\\Diagnostics\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Modules\\Diagnostics\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
